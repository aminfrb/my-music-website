# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database (MongoDB) ─────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/harmony

# ── Auth / JWT (email + password) ──────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── Uploads & limits ───────────────────────────────────
MAX_AUDIO_BYTES=52428800   # 50 MB
MAX_IMAGE_BYTES=5242880    # 5 MB
AUTO_PUBLISH=false
DAILY_UPLOAD_LIMIT_NEW=3
DAILY_UPLOAD_LIMIT=10
DAILY_UPLOAD_LIMIT_TRUSTED=50
NEW_USER_AGE_HOURS=48

# ── Object storage (S3-compatible: MinIO / R2 / S3) ────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=harmony-media
S3_ACCESS_KEY_ID=harmony
S3_SECRET_ACCESS_KEY=harmony-secret
S3_FORCE_PATH_STYLE=true
PRESIGN_GET_TTL=3600
PRESIGN_PUT_TTL=900

# ── Internationalization ───────────────────────────────
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fa
